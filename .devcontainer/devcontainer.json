{
	"name": "knitpick",
	"image": "mcr.microsoft.com/devcontainers/typescript-node:22",
	"features": {
		"ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
	},
	"forwardPorts": [5173],
	"portsAttributes": {
		"5173": { "label": "vite dev" }
	},
	"postCreateCommand": "npm install",
	"customizations": {
		"vscode": {
			"extensions": ["svelte.svelte-vscode"]
		}
	}
}
